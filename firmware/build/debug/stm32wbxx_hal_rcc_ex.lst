 195:Drivers/STM32WBxx_HAL_Driver/Inc/stm32wbxx_ll_crs.h **** #define __LL_CRS_CALC_CALCULATE_RELOADVALUE(__FTARGET__, __FSYNC__) (((__FTARGET__) / (__FSYNC__)) 
